{
  "name": "tool-site",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3006",
    "dev:clean": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true,maxRetries:10,retryDelay:200});console.log('✅ .next cleaned')\" && next dev -p 3006",
    "dev:all": "npx --yes concurrently -n web,seo -c blue,magenta \"npm run dev\" \"npm run admin:seo\"",
    "build": "node scripts/next-build.js",
    "postbuild": "node scripts/postbuild-restore-api.js",
    "start": "next start -p 3006",
    "lint": "next lint",
    "env:sync": "node scripts/sync-local-env.js",
    "sync-locales": "tsx scripts/sync-locales.ts",
    "sync-individual": "tsx scripts/sync-individual-locales.ts",
    "sync-exact": "tsx scripts/sync-exact-copy.ts",
    "pre-deploy": "node scripts/pre-deploy-check.js",
    "prebuild": "node scripts/prebuild-check.js",
    "build:prompt-shards": "node scripts/build-prompt-data-shards.js",
    "audit:prompt-titles": "node scripts/audit-prompt-titles.js",
    "admin:seo": "node scripts/admin-seo-server.js",
    "admin:seo:restart": "pkill -f 'admin-seo-server' 2>/dev/null; sleep 1; node scripts/admin-seo-server.js",
    "test:admin": "npx --yes tsx --test src/lib/admin/*.test.ts"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.2",
    "@xenova/transformers": "^2.17.2",
    "emoji-picker-react": "^4.5.0",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^20.19.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
